@model EmployeeManagementSystemMVC_ADONET.Models.Employee

<h2 class="text-2xl font-bold text-blue-700 mb-4">Edit Employee</h2>

<form asp-action="Edit" method="post" class="bg-white p-6 shadow rounded space-y-4">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="EmpId" />

    <div>
        <label>Name</label>
        <input asp-for="Name" class="w-full border p-2 rounded" />
        <span asp-validation-for="Name" class="text-red-600"></span>
    </div>

    <div>
        <label>Aadhar Card</label>
        <input asp-for="AadharCard" class="w-full border p-2 rounded" />
        <span asp-validation-for="AadharCard" class="text-red-600"></span>
    </div>

    <div>
        <label>Address</label>
        <textarea asp-for="Address" class="w-full border p-2 rounded"></textarea>
        <span asp-validation-for="Address" class="text-red-600"></span>
    </div>

    <div>
        <label>Date of Birth</label>
        <input asp-for="DOB" type="date" class="w-full border p-2 rounded" />
        <span asp-validation-for="DOB" class="text-red-600"></span>
    </div>

    <div>
        <label>Salary</label>
        <input asp-for="Salary" type="number" step="0.01"
               class="w-full border p-2 rounded" />
        <span asp-validation-for="Salary" class="text-red-600"></span>
    </div>

    <button type="submit"
            class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
        Update
    </button>

    <a asp-action="Index" class="ml-3 text-gray-600">Back</a>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
