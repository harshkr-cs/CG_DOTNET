@model StudentRegistrationSystemWithMVC_ADONET.Models.Student

<h2>Student Registration</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <input asp-for="StudentCode" placeholder="Student ID" />
    <span asp-validation-for="StudentCode"></span>
    <br />

    <input asp-for="Name" placeholder="Name" />
    <span asp-validation-for="Name"></span>
    <br />

    <input asp-for="FatherName" placeholder="Father Name" />
    <br />

    <input asp-for="MotherName" placeholder="Mother Name" />
    <br />

    <textarea asp-for="Address" placeholder="Address"></textarea>
    <br />

    <input asp-for="Mobile" placeholder="Mobile" />
    <span asp-validation-for="Mobile"></span>
    <br />

    <input asp-for="Email" placeholder="Email" />
    <span asp-validation-for="Email"></span>
    <br />

    <input type="file" name="ImageFile" required />
    <br /><br />

    <button type="submit">Register</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}